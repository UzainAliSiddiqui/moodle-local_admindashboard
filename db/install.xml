<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/admindashboard/db" VERSION="2026031901" COMMENT="Admin dashboard plugin tables"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_admindashboard_modulereport" COMMENT="Tracks module reports already emailed">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="sectionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_section_uix" UNIQUE="true" FIELDS="courseid, sectionid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_admindashboard_atrisk" COMMENT="Cached at-risk participants for the dashboard">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="riskscore" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="loginrisk" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="pacingrisk" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="pretestrisk" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="dayssincelogin" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="completionpct" TYPE="number" LENGTH="10,2" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="deadlineat" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="pretestpct" TYPE="number" LENGTH="10,2" NOTNULL="false"/>
        <FIELD NAME="pretestavgpct" TYPE="number" LENGTH="10,2" NOTNULL="false"/>
        <FIELD NAME="reasonsjson" TYPE="text" LENGTH="medium" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_user_uix" UNIQUE="true" FIELDS="courseid, userid"/>
        <INDEX NAME="course_score_ix" UNIQUE="false" FIELDS="courseid, riskscore"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
